# 复制为 .env 后填写真实连接信息（.env 已加入 .gitignore，勿提交）
# 可使用 mysql+pymysql:// 或 mysql+asyncmy://；应用运行时会自动转为 asyncmy，Alembic 会转为 pymysql。
# 密码含 @、:、% 等时：在 URL 中须做百分号编码（@ -> %40，: -> %3A，% -> %25），
# 或改用下面「分项配置」，密码可写明文，无需编码。
# KINIT_DATABASE_URL=mysql+pymysql://USER:PASSWORD@HOST:3306/DATABASE
#
# 分项配置（与 KINIT_DATABASE_URL 二选一；设置 URL 时忽略此项）
# KINIT_DATABASE_HOST=8.137.33.38
# KINIT_DATABASE_PORT=33306
# KINIT_DATABASE_NAME=kinit
# KINIT_DATABASE_USER=root
# KINIT_DATABASE_PASSWORD=你的明文密码可含@符号

# 是否启用 MongoDB（可选）。未设置时沿用 application/config/*.py 中的 MONGO_DB_ENABLE。
# 设为 false / 0 / no 等则关闭 Mongo，操作审计与定时任务走 MySQL（须已配置 KINIT_DATABASE_URL 并完成迁移）。
# MONGO_DB_ENABLE=false

# Redis：启用时（默认见 application/config/*.py 中 REDIS_DB_ENABLE）必须配置 KINIT_REDIS_URL。
# 关闭 Redis：REDIS_DB_ENABLE=false（与 MONGO_DB_ENABLE 同样支持 true/false、1/0、yes/no 等）
# 无密码示例：
# KINIT_REDIS_URL=redis://127.0.0.1:6379/0
# 有密码示例（注意 redis://:密码@ 中的冒号）：
# KINIT_REDIS_URL=redis://:YOUR_PASSWORD@127.0.0.1:6379/1
# TLS 使用 rediss:// 前缀。
# REDIS_DB_ENABLE=true
# KINIT_REDIS_URL=redis://127.0.0.1:6379/0
