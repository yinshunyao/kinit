# 环境
VITE_NODE_ENV=development

# 接口 baseURL（axios）。开发环境常用 /api，由下方 VITE_DEV_PROXY_* 转发到真实后端
VITE_API_BASE_URL=/api

# 开发服务器代理：将 VITE_API_BASE_URL 指向的后端、以及媒体路径转发到该地址（仅 pnpm dev 生效）
VITE_DEV_PROXY_TARGET=http://127.0.0.1:46000
# 与后端静态/上传资源路径一致，需与 vite 代理键一致
VITE_DEV_PROXY_MEDIA_PATH=/media

# 后端对外基址（Logo、上传文件等浏览器直接请求的地址）。留空则使用根相对路径（同源或 dev 代理）
# VITE_PUBLIC_BACKEND_URL=http://127.0.0.1:9000

# 打包路径
VITE_BASE_PATH=/

# 是否删除debugger
VITE_DROP_DEBUGGER=false

# 是否删除console.log
VITE_DROP_CONSOLE=false

# 是否sourcemap
VITE_SOURCEMAP=true

# 输出路径
VITE_OUT_DIR=dist-dev

# 标题
VITE_APP_TITLE=后台系统-开发

# 是否切割css
VITE_USE_CSS_SPLIT=true

# 是否使用在线图标
VITE_USE_ONLINE_ICON=true

# 是否包分析
VITE_USE_BUNDLE_ANALYZER=true

# 是否全量引入element-plus样式
VITE_USE_ALL_ELEMENT_PLUS_STYLE=true
